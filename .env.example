# AI Service Credentials for Strands Agents
# Choose ONE of the following providers:

# Option A: Anthropic (Claude) - Recommended for educational content
# Replace 'your_anthropic_api_key_here' with your actual API key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option B: OpenAI (GPT)
# OPENAI_API_KEY=your_openai_api_key_here

# Option C: Google (Gemini)
# GOOGLE_API_KEY=

# Option D: AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=bedrock-api-key

BEDROCK_KNOWLEDGE_BASE_ID= 
BEDROCK_DATA_SOURCE_ID=
S3_KNOWLEDGE_BUCKET="educational-knowledge-base"

# Application Settings
DEBUG=true
LOG_LEVEL=INFO

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR=uploads
